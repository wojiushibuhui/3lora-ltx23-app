lized_name":"value","name":"value","type":"INT","links":[3]}],"properties":{"cnr_id":"comfyui-kjnodes","ver":"3fcd22f2fe2be69c3229f192362b91888277cbcb","Node name for S&R":"INTConstant","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.2.2"}},"widgets_values":[5],"color":"#1b4669","bgcolor":"#29699c","shape":1},{"id":12,"type":"INTConstant","pos":[202.38220660208103,-1713.3303541423725],"size":[279.732421875,60.27608108520508],"flags":{},"order":2,"mode":0,"inputs":[{"label":"值","localized_name":"value","name":"value","type":"INT","widget":{"name":"value"},"link":null}],"outputs":[{"label":"值","localized_name":"value","name":"value","type":"INT","links":[]}],"properties":{"cnr_id":"comfyui-kjnodes","ver":"3fcd22f2fe2be69c3229f192362b91888277cbcb","Node name for S&R":"INTConstant","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.2.2"}},"widgets_values":[81],"color":"#1b4669","bgcolor":"#29699c","shape":1},{"id":13,"type":"MarkdownNote","pos":[-472.66474518307535,-2213.89824587805],"size":[488.2274490204486,651.6832915683483],"flags":{},"order":3,"mode":0,"inputs":[],"outputs":[],"properties":{"ue_properties":{"widget_ue_connectable":{},"version":"7.5.2","input_ue_unconnectable":{}}},"widgets_values":["ComfyUI 视频帧数设置\n用“秒数 × 帧率”算出帧数，并确保输出帧率一致。\n\n1. 如何设置帧数？\n\n公式是：（你想要的秒数 × 帧率） + 1 = 总帧数\n\n例子 5 * 16 + 1 = 81帧 来说明：\n\n· 5：是你想要的视频秒数。\n· 16：是视频每秒的帧数（帧率）。\n· +1：是因为模型要求的初始预测片段。\n\n简单操作： 在工作流里，找到设置总帧数的地方（比如显示81、49的数字），把它改成你按公式算出的新数字。\n\n2. 最关键的一步：统一帧率\n\n你计算时用的帧率，必须和最终输出视频的帧率设为同一个数。\n\n· 正确示例：用81帧，输出帧率也设16，得到约5秒的视频。\n· 错误示例：用81帧，但输出帧率设了24，那视频时长就变成了 81 ÷ 24 ≈ 3.3秒，结果会快进。\n\n总结：先按公式（秒数×帧率+1）算出总帧数（如81），再去设置里把这个帧率（如16）填到输出帧率上，时长就准了。"],"color":"#432","bgcolor":"#653","shape":1},{"id":17,"type":"VHS_LoadVideo","pos":[1280.8815498361953,-2211.9622442893838],"size":[261.6533203125,753.272357822205],"flags":{},"order":4,"mode":0,"inputs":[{"label":"批次管理","localized_name":"meta_batch","name":"meta_batch","shape":